# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Build output
/bin/

# Dependency directories (remove the comment below to include it)
# vendor/
design/
design
/design
.claude
.claude/
/.claude

# Local-only working guidance (kept private; the authoritative plan lives in design/)
CLAUDE.md

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/
